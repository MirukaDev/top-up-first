# MirukaStore Environment Configuration
# Copy file ini ke .env dan sesuaikan dengan konfigurasi Anda

# Database Configuration
DB_HOST=localhost
DB_NAME=mirukastore
DB_USER=root
DB_PASS=

# Midtrans Configuration
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXXXXXX
MIDTRANS_IS_PRODUCTION=false

# Digiflazz Configuration
DIGIFLAZZ_USERNAME=your_digiflazz_username
DIGIFLAZZ_API_KEY=your_digiflazz_api_key

# VIP Reseller Configuration (Alternative)
VIP_RESELLER_API_KEY=your_vip_reseller_api_key

# Application Configuration
APP_NAME=MirukaStore
APP_URL=http://localhost/MirukaStore
APP_DEBUG=true

# Contact Configuration
CONTACT_WHATSAPP=081219748457
CONTACT_EMAIL=support@mirukastore.com
